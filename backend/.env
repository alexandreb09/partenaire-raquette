###> symfony/framework-bundle ###
APP_ENV=dev
APP_DEBUG=true
APP_SECRET=tennis_partner_secret_key_change_in_prod
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost:8000
###< symfony/framework-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:@127.0.0.1:3306/tennis_partner?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=tennis_partner_jwt_passphrase
###< lexik/jwt-authentication-bundle ###

###> symfony/mailer ###
MAILER_DSN=brevo+api://YOUR_BREVO_API_KEY@default
MAILER_FROM_EMAIL=noreply@sportio.fr
MAILER_FROM_NAME="Sportio"
# Comma-separated list of moderator emails that receive report notifications
MODERATION_EMAILS=admin@sportio.fr
###< symfony/mailer ###
